{
    "api_keys": {
        "enabled": true,
        "keys": [],
        "key_header": "X-API-Key",
        "rotation_days": 90,
        "description": "API Key 인증 설정. enabled를 true로 유지하고, 환경변수 CHATBOT_API_KEYS (쉼표 구분)로 키를 설정하세요. 프로덕션에서는 반드시 복잡한 키 사용 및 90일마다 로테이션 권장."
    },
    "rate_limit": {
        "enabled": true,
        "max_requests_per_minute": 60,
        "max_requests_per_hour": 1000,
        "window_seconds": 60,
        "description": "IP 기반 레이트 리밋 설정. /api/chat 엔드포인트 및 일반 API에 적용됩니다. 분당 제한과 시간당 제한 동시 적용."
    },
    "session": {
        "timeout_minutes": 30,
        "secure_cookie": true,
        "httponly_cookie": true,
        "samesite_cookie": "Strict",
        "description": "세션 타임아웃은 30분. 쿠키는 Secure, HttpOnly, SameSite=Strict로 설정되어 CSRF/XSS 공격 방지."
    },
    "input_validation": {
        "max_query_length": 5000,
        "max_message_length": 10000,
        "max_batch_size": 100,
        "forbidden_patterns": [
            "(?i)union.*select",
            "(?i)drop.*table",
            "(?i)insert.*into",
            "(?i)delete.*from",
            "(?i)update.*set",
            "(?i)exec\\s*\\(",
            "(?i)execute\\s*\\(",
            "<script[^>]*>",
            "javascript:",
            "onerror\\s*=",
            "onclick\\s*=",
            "onload\\s*="
        ],
        "description": "SQL Injection, 스크립트 주입, 이벤트 핸들러 공격 등을 방지. 정규식은 case-insensitive로 처리."
    },
    "cors": {
        "enabled": true,
        "allowed_origins": [
            "https://yourdomain.com",
            "https://www.yourdomain.com"
        ],
        "allowed_methods": ["GET", "POST", "OPTIONS"],
        "allowed_headers": ["Content-Type", "X-API-Key", "Authorization"],
        "expose_headers": ["X-RateLimit-Limit", "X-RateLimit-Remaining", "X-RateLimit-Reset"],
        "max_age_seconds": 3600,
        "allow_credentials": true,
        "description": "CORS 설정. 프로덕션 배포 시 yourdomain.com을 실제 도메인으로 변경하세요."
    },
    "security_headers": {
        "x_frame_options": "SAMEORIGIN",
        "x_content_type_options": "nosniff",
        "x_xss_protection": "1; mode=block",
        "strict_transport_security": "max-age=63072000; includeSubDomains; preload",
        "referrer_policy": "strict-origin-when-cross-origin",
        "permissions_policy": "geolocation=(), microphone=(), camera=()",
        "description": "응용프로그램 보안 헤더 설정. HSTS는 SSL 활성화 후 적용."
    },
    "encryption": {
        "enable_tls": true,
        "min_tls_version": "1.2",
        "description": "TLS 1.2 이상 사용 필수. 프로덕션에서는 TLS 1.3 권장."
    },
    "logging": {
        "log_api_requests": true,
        "log_failed_auth": true,
        "log_rate_limit_exceeded": true,
        "log_input_validation_failures": true,
        "sensitive_fields_to_mask": ["X-API-Key", "Authorization", "password"],
        "description": "모든 보안 이벤트 로깅. 민감한 필드는 자동으로 마스킹됨."
    },
    "exempt_paths": [
        "/",
        "/api/health",
        "/static",
        "/manifest.json",
        "/sw.js"
    ]
}
