# =====================================================================
# Bonded Exhibition Chatbot - Environment Variables
#
# Copy this file:   cp .env.example .env
# Then fill in the values you need. All variables here have safe defaults
# for local development; you only MUST set ANTHROPIC_API_KEY (optional, for
# LLM fallback) and JWT_SECRET / ADMIN_USERS for production deployments.
# =====================================================================

# --- Server ----------------------------------------------------------
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8080
# Host port published to your machine (Docker only). Useful if 8080 is taken.
CHATBOT_HOST_PORT=8080

# --- LLM fallback (optional) -----------------------------------------
# Used when FAQ matching is too weak; falls back to Anthropic Claude.
ANTHROPIC_API_KEY=

# --- Auth (required for production) ----------------------------------
JWT_SECRET=
ADMIN_USERS=admin

# --- National Law Information Center Open API ------------------------
# law.go.kr Open API authentication key (your account email ID).
# Leaving this empty works for low-volume read access (no auth required
# for public endpoints), but setting it raises the rate limit.
# Used by:
#   - src/law_api_sync.py        (laws / Customs Act etc.)
#   - src/law_api_admrul.py      (admRul: notices/directives, e.g.
#                                 "보세전시장 운영에 관한 고시"
#                                 admRulSeq=2100000276240)
#   - scripts/refresh_law_data.py
LAW_API_OC=
