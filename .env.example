# ============================================================
# 보세전시장 챗봇 환경변수 (env)
# ------------------------------------------------------------
# 1. 이 파일을 .env로 복사:  cp .env.example .env
# 2. 아래 항목 중 [필수] 표시된 값만 채워도 동작합니다.
# 3. .env 는 절대 git 커밋하지 마세요 (.gitignore 등록됨).
# ============================================================

# ── [필수] LLM 폴백 (FAQ 매칭 실패 시 Anthropic Claude 호출) ──
# 발급:  https://console.anthropic.com/settings/keys
# 비워두면 LLM 폴백 비활성화 (FAQ만으로 동작)
ANTHROPIC_API_KEY=
CHATBOT_LLM_MODEL=claude-sonnet-4-5-20250929

# ── [필수] JWT 시크릿 (관리자 로그인 토큰 서명) ──
# 강력한 랜덤 문자열로 변경하세요!
# 생성:  python -c "import secrets; print(secrets.token_urlsafe(64))"
#        또는: openssl rand -base64 64
JWT_SECRET_KEY=change-me-please-please-please-use-secrets-token_urlsafe-64

# ── [필수] 관리자 계정 (JSON 배열, 비밀번호는 SHA-256 해시) ──
# 비밀번호 해시 생성:
#   python -c "from src.auth import hash_password; print(hash_password('mypassword'))"
# 예시 (admin / admin123 — 운영에서는 반드시 교체):
# ADMIN_USERS=[{"username":"admin","password_hash":"240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9","role":"admin"}]
ADMIN_USERS=

# ── 챗봇 API 키 (REST 호출 인증, 콤마 구분) ──
# 비워두면 인증 비활성화 (개발/내부용).
# 운영에서는 최소 1개 이상 권장.
# CHATBOT_API_KEYS=key-prod-1,key-prod-2
CHATBOT_API_KEYS=

# ── CORS 허용 오리진 (콤마 구분) ──
# 운영에서는 *(전체 허용) 대신 실제 도메인만 등록하세요.
# CHATBOT_CORS_ORIGINS=https://chatbot.example.com,https://admin.example.com
CHATBOT_CORS_ORIGINS=*

# ── Flask 환경 ──
# production: 디버그 OFF, 에러페이지 최소화 (운영 기본)
# development: 디버그 ON, traceback 노출 (로컬만)
FLASK_ENV=production
CHATBOT_DEBUG=false

# ── 로그 레벨 ──
# DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
CHATBOT_LOG_LEVEL=INFO

# ── 서버 바인딩 ──
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8080

# ── 데이터베이스 (SQLite 기본, PostgreSQL 선택) ──
CHATBOT_DB_PATH=logs/chat_logs.db
# DATABASE_URL=postgresql://user:password@localhost:5432/bonded_chatbot

# ── Gunicorn (Docker 컨테이너에서만 적용) ──
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:8080

# ── HuggingFace 모델 캐시 (sentence-transformers) ──
# 컨테이너 내부 경로. docker-compose 가 hf-cache 볼륨으로 영구화함.
HF_HOME=/app/.hf_cache
TRANSFORMERS_CACHE=/app/.hf_cache

# ── 알림 (선택) ──
# Slack incoming webhook (장애/일일 보고).
# 발급:  https://api.slack.com/apps → Incoming Webhooks
# 형식 예시 (실제 URL은 본인 워크스페이스에서 받은 값):
#   SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<TEAM>/<CHANNEL>/<TOKEN>
# SLACK_WEBHOOK_URL=
