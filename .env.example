# =====================================================================
# Bonded Exhibition Chatbot - Environment Variables
#
# Copy this file:   cp .env.example .env
# Then fill in the values you need. All variables here have safe defaults
# for local development; you only MUST set ANTHROPIC_API_KEY (optional, for
# LLM fallback) and JWT_SECRET / ADMIN_USERS for production deployments.
# =====================================================================

# ─── Server ─────────────────────────────────────────────────────────
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8080
# Host port published to your machine (Docker only). Useful if 8080 is taken.
CHATBOT_HOST_PORT=8080
CHATBOT_DEBUG=false
CHATBOT_LOG_LEVEL=INFO
FLASK_ENV=production            # development | production

# ─── Database ──────────────────────────────────────────────────────
CHATBOT_DB_PATH=logs/chat_logs.db
# Optional: PostgreSQL for production multi-instance deployments
# DATABASE_URL=postgresql://user:password@localhost:5432/bonded_chatbot

# ─── Caching / Models ──────────────────────────────────────────────
# Where sentence-transformers downloads HuggingFace models. Mounting this as
# a Docker volume avoids re-downloading on every container restart.
HF_HOME=./.hf-cache
# Redis for rate-limiting and request cache. Optional in dev.
# REDIS_URL=redis://localhost:6379/0

# ─── Security ──────────────────────────────────────────────────────
# CORS: comma-separated origins, or "*" for any (dev only).
CHATBOT_CORS_ORIGINS=*

# Comma-separated API keys required by external clients. Empty = open.
# CHATBOT_API_KEYS=key1,key2

# JWT secret for /api/auth/login. MUST be set and rotated for production.
# Generate one:   python -c "import secrets; print(secrets.token_urlsafe(64))"
# JWT_SECRET=change-me-to-a-long-random-string

# Admin users as JSON array of {username, password_hash}.
# Hash a password:  python -c "from src.auth import hash_password; print(hash_password('YOUR_PASS'))"
# ADMIN_USERS=[{"username":"admin","password_hash":"$2b$12$..."}]

# ─── LLM Fallback (optional) ───────────────────────────────────────
# When set, unmatched questions fall back to Claude. Without it, the bot
# returns the FAQ matcher's "no match" response.
# ANTHROPIC_API_KEY=sk-ant-...
CHATBOT_LLM_MODEL=claude-sonnet-4-6

# ─── Notifications (optional) ──────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ─── Gunicorn (production server) ──────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:8080
