# ===========================================
# 보세전시장 챗봇 환경변수 설정
# 이 파일을 .env로 복사하여 사용하세요
# cp .env.example .env
# ===========================================

# --- 서버 설정 ---
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8080
CHATBOT_DEBUG=false
CHATBOT_LOG_LEVEL=INFO

# --- 데이터베이스 ---
CHATBOT_DB_PATH=logs/chat_logs.db

# --- 보안 ---
# API 키 (콤마 구분, 비워두면 인증 비활성화)
# CHATBOT_API_KEYS=your-api-key-1,your-api-key-2
# CORS 허용 오리진 (콤마 구분, *는 전체 허용)
CHATBOT_CORS_ORIGINS=*

# --- LLM 폴백 (선택) ---
# Anthropic Claude API 키 (LLM 폴백 사용 시)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM 모델명
# CHATBOT_LLM_MODEL=claude-sonnet-4-20250514

# --- PostgreSQL (프로덕션용, 선택) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/bonded_chatbot

# --- Gunicorn ---
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:8080
