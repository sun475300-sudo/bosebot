diff --git a/tests/test_rate_limit_env.py b/tests/test_rate_limit_env.py
new file mode 100644
index 0000000..b94f5bd
--- /dev/null
+++ b/tests/test_rate_limit_env.py
@@ -0,0 +1,55 @@
+"""Patch 0003 — rate-limit endpoint defaults overridable via env vars."""
+import importlib, os, pytest
+
+
+def _reload():
+    import src.rate_limiter_v2 as m
+    return importlib.reload(m)
+
+
+@pytest.fixture(autouse=True)
+def cleanup():
+    yield
+    for k in ("CHAT_RPM","FAQ_RPM","ADMIN_RPM","AUTOCOMPLETE_RPM","SEARCH_RPM"):
+        os.environ.pop(k, None)
+
+
+def test_default_limits_match_legacy():
+    rl = _reload().AdvancedRateLimiter()
+    assert rl._endpoint_limits["/api/chat"] == 30
+    assert rl._endpoint_limits["/api/faq"] == 60
+    assert rl._endpoint_limits["/api/admin/*"] == 20
+    assert rl._endpoint_limits["/api/autocomplete"] == 120
+
+
+def test_chat_rpm_env_override():
+    os.environ["CHAT_RPM"] = "180"
+    rl = _reload().AdvancedRateLimiter()
+    assert rl._endpoint_limits["/api/chat"] == 180
+
+
+def test_invalid_env_falls_back_to_default():
+    os.environ["CHAT_RPM"] = "not-a-number"
+    rl = _reload().AdvancedRateLimiter()
+    assert rl._endpoint_limits["/api/chat"] == 30
+
+
+def test_zero_or_negative_falls_back():
+    os.environ["CHAT_RPM"] = "0"
+    rl = _reload().AdvancedRateLimiter()
+    assert rl._endpoint_limits["/api/chat"] == 30
+    os.environ["CHAT_RPM"] = "-5"
+    rl = _reload().AdvancedRateLimiter()
+    assert rl._endpoint_limits["/api/chat"] == 30
+
+
+def test_search_rpm_added():
+    os.environ["SEARCH_RPM"] = "240"
+    rl = _reload().AdvancedRateLimiter()
+    assert rl._endpoint_limits["/api/search/*"] == 240
+
+
+def test_explicit_kwarg_overrides_env():
+    os.environ["CHAT_RPM"] = "100"
+    rl = _reload().AdvancedRateLimiter(endpoint_limits={"/api/chat": 50})
+    assert rl._endpoint_limits["/api/chat"] == 50
