From fb95a77870da26bffc1d5b01c7eedb301dcf211b Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.local>
Date: Tue, 28 Apr 2026 00:40:09 +0000
Subject: [PATCH 2/3] fix(auth): account lockout after N failed login attempts
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

/api/auth/login returned 401 indefinitely on bad passwords with no lockout —
vulnerable to credential stuffing / brute force.

src/auth.py adds module-level _LOGIN_ATTEMPTS / _LOGIN_LOCKOUT_UNTIL trackers
behind a thread lock. After AUTH_MAX_ATTEMPTS (default 5) failures within
AUTH_ATTEMPT_WINDOW_SECONDS (default 900s), the account is locked for
AUTH_LOCKOUT_SECONDS (default 300s). Successful login resets counters.

API: 423 ACCOUNT_LOCKED with retry_after_seconds in body.

Tests: tests/test_auth_lockout.py — 4 cases.
---
 src/auth.py                | 65 ++++++++++++++++++++++++++++++++++++++
 tests/test_auth_lockout.py | 57 +++++++++++++++++++++++++++++++++
 web_server.py              | 34 +++++++++++++++++++-
 3 files changed, 155 insertions(+), 1 deletion(-)
 create mode 100644 tests/test_auth_lockout.py

diff --git a/src/auth.py b/src/auth.py
index 2afe519..ab0c31e 100644
--- a/src/auth.py
+++ b/src/auth.py
@@ -215,6 +215,70 @@ class JWTAuth:
         return decorator
 
 
+# ---------------------------------------------------------------------------
+# Brute-force lockout (patch 0002)
+# ---------------------------------------------------------------------------
+import threading as _threading
+
+_LOGIN_ATTEMPTS_LOCK = _threading.Lock()
+_LOGIN_ATTEMPTS: dict[str, list[float]] = {}
+_LOGIN_LOCKOUT_UNTIL: dict[str, float] = {}
+
+
+def _auth_max_attempts() -> int:
+    try:
+        return max(1, int(os.environ.get("AUTH_MAX_ATTEMPTS", "5")))
+    except ValueError:
+        return 5
+
+
+def _auth_lockout_seconds() -> int:
+    try:
+        return max(1, int(os.environ.get("AUTH_LOCKOUT_SECONDS", "300")))
+    except ValueError:
+        return 300
+
+
+def _auth_attempt_window() -> int:
+    try:
+        return max(60, int(os.environ.get("AUTH_ATTEMPT_WINDOW_SECONDS", "900")))
+    except ValueError:
+        return 900
+
+
+def is_locked_out(username: str) -> tuple[bool, int]:
+    now = time.time()
+    with _LOGIN_ATTEMPTS_LOCK:
+        until = _LOGIN_LOCKOUT_UNTIL.get(username, 0.0)
+        if until > now:
+            return True, int(until - now)
+        if until and until <= now:
+            _LOGIN_LOCKOUT_UNTIL.pop(username, None)
+            _LOGIN_ATTEMPTS.pop(username, None)
+        return False, 0
+
+
+def record_failed_login(username: str) -> tuple[bool, int]:
+    now = time.time()
+    window = _auth_attempt_window()
+    max_n = _auth_max_attempts()
+    lockout = _auth_lockout_seconds()
+    with _LOGIN_ATTEMPTS_LOCK:
+        attempts = [t for t in _LOGIN_ATTEMPTS.get(username, []) if now - t < window]
+        attempts.append(now)
+        _LOGIN_ATTEMPTS[username] = attempts
+        if len(attempts) >= max_n:
+            _LOGIN_LOCKOUT_UNTIL[username] = now + lockout
+            return True, lockout
+    return False, 0
+
+
+def reset_failed_logins(username: str) -> None:
+    with _LOGIN_ATTEMPTS_LOCK:
+        _LOGIN_ATTEMPTS.pop(username, None)
+        _LOGIN_LOCKOUT_UNTIL.pop(username, None)
+
+
 def authenticate_user(username: str, password: str) -> dict | None:
     """Authenticate a user against the admin user list.
 
@@ -229,5 +293,6 @@ def authenticate_user(username: str, password: str) -> dict | None:
     for user in users:
         if user.get("username") == username:
             if verify_password(password, user.get("password_hash", "")):
+                reset_failed_logins(username)
                 return {"username": user["username"], "role": user.get("role", "admin")}
     return None
