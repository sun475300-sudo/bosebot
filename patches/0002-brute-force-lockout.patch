+++ b/tests/test_auth_lockout.py
@@ -0,0 +1,57 @@
+"""Patch 0002 — brute-force lockout for /api/auth/login."""
+import os, time, pytest
+os.environ["AUTH_MAX_ATTEMPTS"] = "5"
+os.environ["AUTH_LOCKOUT_SECONDS"] = "2"
+os.environ["AUTH_ATTEMPT_WINDOW_SECONDS"] = "60"
+
+from web_server import app
+from src.auth import _LOGIN_ATTEMPTS, _LOGIN_LOCKOUT_UNTIL, is_locked_out
+
+
+@pytest.fixture
+def client():
+    app.config["TESTING"] = False
+    _LOGIN_ATTEMPTS.clear()
+    _LOGIN_LOCKOUT_UNTIL.clear()
+    with app.test_client() as c:
+        yield c
+    _LOGIN_ATTEMPTS.clear()
+    _LOGIN_LOCKOUT_UNTIL.clear()
+
+
+def test_lockout_after_5_failures(client):
+    for i in range(5):
+        r = client.post("/api/auth/login", json={"username": "admin", "password": f"x{i}"})
+        assert r.status_code in (401, 423)
+    r = client.post("/api/auth/login", json={"username": "admin", "password": "x6"})
+    assert r.status_code == 423
+    body = r.get_json()
+    assert body["error_code"] == "ACCOUNT_LOCKED"
+    assert body["retry_after_seconds"] >= 1
+
+
+def test_correct_password_during_lockout_still_blocked(client):
+    for i in range(5):
+        client.post("/api/auth/login", json={"username": "admin", "password": "x"})
+    r = client.post("/api/auth/login", json={"username": "admin", "password": "admin123"})
+    assert r.status_code == 423
+
+
+def test_lockout_expires_and_login_works(client):
+    for i in range(5):
+        client.post("/api/auth/login", json={"username": "admin", "password": "x"})
+    time.sleep(2.2)
+    r = client.post("/api/auth/login", json={"username": "admin", "password": "admin123"})
+    assert r.status_code == 200, r.data
+    assert "token" in r.get_json()
+
+
+def test_reset_on_successful_login(client):
+    for i in range(3):
+        client.post("/api/auth/login", json={"username": "admin", "password": "x"})
+    r = client.post("/api/auth/login", json={"username": "admin", "password": "admin123"})
+    assert r.status_code == 200
+    for i in range(4):
+        client.post("/api/auth/login", json={"username": "admin", "password": "x"})
+    locked, _ = is_locked_out("admin")
+    assert not locked
