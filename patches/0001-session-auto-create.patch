         categories = classify_query(query)
         escalation = check_escalation(query)
-        # 세션 ID 처리 (선택적)
+        # 세션 ID 처리 (선택적). 클라이언트가 임의 session_id를 보낸 경우
+        # 컨텍스트가 누락되지 않도록 자동 생성한다 (patch 0001).
         session_id = data.get("session_id")
+        if session_id and isinstance(session_id, str) and hasattr(chatbot.session_manager, "ensure_session"):
+            try:
+                chatbot.session_manager.ensure_session(session_id)
+            except Exception as e:
+                logger.warning(f"ensure_session failed for {session_id}: {e}")
 
         # 엔티티 추출 V2
         try:
